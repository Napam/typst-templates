#!/usr/bin/env bash
# Pre-commit hook: compile all template examples before committing.
# Keeps example PDFs in sync with template source.
set -euo pipefail

# Run from the repo root regardless of where git is invoked from.
cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: building all templates..."
just build

# Stage regenerated PDFs so they're included in the commit.
git add templates/*/example.pdf